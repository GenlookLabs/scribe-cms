{
  "name": "scribe-cms",
  "version": "0.0.12",
  "description": "Typed, file-based CMS for multilingual MDX sites",
  "homepage": "https://scribe.genlook.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/GenlookLabs/scribe-cms.git"
  },
  "bugs": {
    "url": "https://github.com/GenlookLabs/scribe-cms/issues"
  },
  "type": "module",
  "license": "MIT",
  "keywords": [
    "cms",
    "mdx",
    "i18n",
    "zod",
    "content",
    "translation"
  ],
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./runtime": {
      "types": "./dist/src/runtime.d.ts",
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.cjs"
    },
    "./studio": {
      "types": "./dist/studio/server.d.ts",
      "import": "./dist/studio/server.js"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "scribe": "./bin/scribe.js"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.dts.json",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "pnpm build && node --import tsx --test \"src/**/*.test.ts\"",
    "prepublishOnly": "pnpm build",
    "publish:npm": "npm publish --access public"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@hono/node-server": "^1.19.9",
    "@inquirer/core": "^11.2.1",
    "@inquirer/prompts": "^8.5.2",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "hono": "^4.11.4",
    "jiti": "^2.6.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "peerDependencies": {
    "zod": "^4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.2",
    "tsup": "^8.5.1",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=20"
  }
}